# Local development signing identity used by make bundle/install
CODESIGN_IDENTITY=MacSmoothScroll Dev

# Production signing identity used by make sign
SIGN_IDENTITY=Developer ID Application: Your Name (TEAMID)

# App Store Connect API key credentials used by notarytool in make sign
APPLE_API_KEY=/absolute/path/to/AuthKey_XXXXXXXXXX.p8
APPLE_API_KEY_ID=XXXXXXXXXX
APPLE_API_ISSUER=00000000-0000-0000-0000-000000000000
